###############################################################################
# KiCad project ignore (clean + practical)
###############################################################################

# --- System / editor junk ---
.DS_Store
Thumbs.db
*.tmp
*.bak
*.swp

# --- KiCad local settings (machine-specific) ---
*.kicad_prl
*.kicad_prl-bak

# --- KiCad autosave / backup ---
*-backup.*
*.autosave
*.kicad_sch-bak
*.kicad_pcb-bak

# --- Simulation / cache ---
*.cache
*.dcm
*.log

# --- Plot / fabrication outputs (regeneratable) ---
*.gbr
*.drl
*.zip
*.step
*.stp
*.pos
*.csv

# --- Python / scripts (if added later) ---
__pycache__/
*.pyc


# --- KiCad runtime junk ---
*_autosave-*.kicad_sch
*~.lck
fp-info-cache


###############################################################################
# IMPORTANT: we DO NOT blanket-ignore everything
# → allows future expansion (libs, variants, etc.)
###############################################################################